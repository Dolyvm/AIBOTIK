from fastapi import APIRouter
from pathlib import Path
import json
import sys

# Add parent directory to path for shared package
sys.path.insert(0, str(Path(__file__).parent.parent.parent))

from shared.card_parser import get_all_characters

router = APIRouter(prefix="/api/characters", tags=["characters"])

# Load once at startup
CHARACTERS = get_all_characters(Path("/app/content/characters"))

with open("/app/content/character_meta.json") as f:
    CHARACTER_META = json.load(f)


@router.get("")
async def list_characters(
    genre: str = None,
    style: str = None  # anime/real
):
    """List all characters with filtering"""
    result = []

    for char_id, char in CHARACTERS.items():
        meta = CHARACTER_META.get(char_id, {})
        tags = meta.get("nsfw_tags", [])
        model_type = meta.get("model_type", "real")

        # Filtering
        if genre and genre not in tags:
            continue
        if style and style != model_type:
            continue

        result.append({
            "id": char_id,
            "name": char["name"],
            "image_url": char["image_url"],
            "tags": tags,
            "model_type": model_type,
            "scenarios_count": 1 + len(char.get("alternate_greetings", []))
        })

    return {"characters": result}


@router.get("/{character_id}")
async def get_character_detail(character_id: str):
    """Detailed character information"""
    char = CHARACTERS.get(character_id)
    if not char:
        return {"error": "Not found"}, 404

    meta = CHARACTER_META.get(character_id, {})

    # Build scenarios list
    scenarios = [{
        "index": 0,
        "name": "Основной",
        "preview": char["first_mes"][:100] + "..." if len(char["first_mes"]) > 100 else char["first_mes"]
    }]

    for i, alt in enumerate(char.get("alternate_greetings", []), 1):
        preview = alt[:100] + "..." if len(alt) > 100 else alt
        scenarios.append({
            "index": i,
            "name": f"Сценарий {i}",
            "preview": preview
        })

    return {
        "id": character_id,
        "name": char["name"],
        "description": char["description"][:500] if len(char["description"]) > 500 else char["description"],
        "personality": char["personality"],
        "image_url": char["image_url"],
        "tags": meta.get("nsfw_tags", []),
        "scenarios": scenarios
    }


@router.get("/filters/options")
async def get_filter_options():
    """Return available filter options"""
    all_tags = set()
    styles = set()

    for char_id in CHARACTERS:
        meta = CHARACTER_META.get(char_id, {})
        all_tags.update(meta.get("nsfw_tags", []))
        styles.add(meta.get("model_type", "real"))

    return {
        "genres": sorted(list(all_tags)),
        "styles": sorted(list(styles))
    }
