    print(pos2)
    print("\nNegative prompt:")
    print(neg2)

    print("\n=== Example 3: Arousal mapping ===")
    for arousal in [0, 20, 40, 60, 75, 95]:
        tier = map_arousal_to_tier(arousal)
        print(f"Arousal {arousal} → {tier}")
